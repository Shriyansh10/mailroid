{
  "extends": "@repo/typescript-config/node.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "moduleResolution": "nodenext",
    "module": "nodenext",

    // We don't need these for our final build
    "declarationMap": false,
    "declaration": false,
    "sourceMap": false
  },
  "include": ["src", "src/scripts/create-instance.ts"],
  "ts-node": {
    "swc": true
  }
}

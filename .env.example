# NOTE: values are intentionally unquoted — `docker run --env-file` does not
# strip surrounding quotes the way dotenv/dotenv-cli does, so quoting a value
# here would pass the literal quote characters into the container's env.

# DB
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mailroid_db
# neon db
DATABASE_URL=neon db connection string here

# Auth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

BETTER_AUTH_SECRET=your-better-auth-secret
BETTER_AUTH_URL=http://localhost:8000

CORSAIR_KEK=your-corsair-kek
CORSAIR_DEV_KEY=your-corsair-dev-key

CORSAIR_INSTANCE_ID=your-corsair-instance-id

# Ai - Deepseek
DEEPSEEK_API_KEY=your-openai-or-deepseek-api-key
DEEPSEEK_CHAT_MODEL=gpt-4o-mini
DEEPSEEK_BASE_URL=https://api.openai.com/v1
# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_CHAT_MODEL=deepseek-v4-pro
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1



# Ai - OpenAI
EMBEDDINGS_API_KEY=your-openai-api-key
EMBEDDINGS_BASE_URL=https://api.openai.com/v1
EMBEDDINGS_MODEL=text-embedding-3-small


GMAIL_PUBSUB_TOPIC=projects/<your-gcp-project>/topics/<your-topic>
# In production (via Caddy path-based routing) BASE_URL and FRONTEND_URL are
# the same origin, e.g. https://mailroid.in for both
BASE_URL=https://your-ngrok-or-public-url
FRONTEND_URL=https://your-ngrok-or-public-url

GMAIL_OAUTH_CALLBACK_URL=https://your-ngrok-or-public-url/api/auth/gmail/callback
CALENDAR_OAUTH_CALLBACK_URL=https://your-ngrok-or-public-url/api/auth/calendar/callback

# Inngest (durable background jobs: email priority classification + the
# resumable full-mailbox Gmail sync). Without these, Inngest events are not
# delivered in production and those jobs silently don't run — the Gmail sync
# then falls back to a non-durable in-process sync at connect time.
# Get both keys from the Inngest dashboard (https://app.inngest.com) after
# registering your app's serve endpoint at {BASE_URL}/api/inngest.
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# Web app
# In production this must be the plain API origin (no /api suffix) —
# better-auth's client appends /api/auth itself, and the tRPC client appends
# /trpc, which the API mounts at root — e.g. https://mailroid.in
NEXT_PUBLIC_API_URL=http://localhost:8000
# SKIP_ENV_VALIDATION=true

# Comma-separated list of emails exempt from daily usage limits
WHITELISTED_EMAILS=you@example.com,teammate@example.com
